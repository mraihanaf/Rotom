// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/@generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Organization {
  id          Int      @id @default(1)
  name        String
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  assignments        Assignment[]
  assignmentStatuses AssignmentStatus[]

  reportedLogs    FundContributionLog[] @relation("ReporterLogs")
  contributedLogs FundContributionLog[] @relation("ContributorLogs")

  galleryPosts     GalleryPost[]
  galleryReactions GalleryPostReaction[]
  dutySchedules    DutySchedule[]

  phoneNumber         String?
  phoneNumberVerified Boolean?
  role                String?
  isProfileComplete   Boolean   @default(false)
  banned              Boolean?  @default(false)
  banReason           String?
  banExpires          DateTime?
  birthday            DateTime?

  // Name change requests
  nameChangeRequests        UserNameChangeRequest[]
  reviewedNameChangeRequests UserNameChangeRequest[] @relation("NameChangeReviewer")

  @@unique([email])
  @@unique([phoneNumber])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Subject {
  id   String @id @default(cuid())
  name String

  schedules   SubjectSchedule[]
  assignments Assignment[]
  createdAt   DateTime          @default(now())

  @@unique([name])
}

model SubjectSchedule {
  id        String  @id @default(cuid())
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0=Sunday .. 6=Saturday
  startTime String // "08:00"
  endTime   String // "09:30"
  room      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@index([dayOfWeek])
}

model Assignment {
  id        String @id @default(cuid())
  subjectId String
  createdBy String

  user    User    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  assignmentStatuses AssignmentStatus[]

  title       String
  description String?
  dueDate     DateTime
  createdAt   DateTime @default(now())

  @@index([subjectId])
  @@index([createdBy])
}

model AssignmentStatus {
  id           String @id @default(uuid())
  userId       String
  assignmentId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  done       Boolean    @default(false)
  createdAt  DateTime   @default(now())

  @@unique([assignmentId, userId])
}

model Fund {
  id               Int                   @id @default(1)
  totalAmount      Float                 @default(0)
  currency         String                @default("idr")
  contributionLogs FundContributionLog[]
}

model FundContributionLog {
  id            String  @id @default(uuid())
  reporterId    String
  contributorId String?
  fundId        Int     @default(1)
  fund          Fund    @relation(fields: [fundId], references: [id], onDelete: Cascade)
  reporter      User    @relation("ReporterLogs", fields: [reporterId], references: [id], onDelete: Cascade)
  contributor   User?   @relation("ContributorLogs", fields: [contributorId], references: [id], onDelete: Cascade)

  currency  String              @default("idr")
  amount    Float
  note      String?
  type      FundTransactionType @default(INCOME)
  createdAt DateTime            @default(now())

  @@index([reporterId])
  @@index([contributorId])
  @@index([type])
}

enum FundTransactionType {
  INCOME
  EXPENSE
}

enum MediaType {
  video
  image
}

model GalleryPost {
  id        String @id @default(cuid())
  userId    String
  createdBy User   @relation(fields: [userId], references: [id])

  reactions GalleryPostReaction[]

  mediaKey String @unique

  type MediaType

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model GalleryPostReaction {
  id        String      @id @default(cuid())
  post      GalleryPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model DutyType {
  id        String   @id @default(cuid())
  name      String
  category  String // "CLEANING" | "MBG"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules DutySchedule[]
}

model DutySchedule {
  id          String    @id @default(cuid())
  dutyTypeId  String
  userId      String
  dayOfWeek   Int // 1=Monday, 5=Friday
  status      String    @default("SCHEDULED") // SCHEDULED | COMPLETED | MISSED | EXCUSED
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dutyType DutyType @relation(fields: [dutyTypeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dutyTypeId, userId, dayOfWeek])
}

model UserNameChangeRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedName String
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  source        String   // COMPLETE_PROFILE | PROFILE_EDIT
  requestedAt   DateTime @default(now())
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    User?    @relation("NameChangeReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason String?

  // Admin notification tracking
  adminsNotified  Boolean  @default(false)
  notifiedAt      DateTime?

  @@index([userId, status])
  @@index([status, requestedAt])
  @@index([requestedAt])
  @@index([adminsNotified, status])
}

model Settings {
  id Int @id @default(1)

  // Enable flags
  ENABLE_WHATSAPP_BOT_FUND_REPORT               Boolean @default(true)
  ENABLE_WHATSAPP_BOT_DUTY_REPORT               Boolean @default(true)
  ENABLE_WHATSAPP_BOT_SUBJECT_SCHEDULE_REMINDER Boolean @default(true)
  ENABLE_WHATSAPP_BOT_BIRTHDAY_REMINDER         Boolean @default(true)
  ENABLE_WHATSAPP_BOT_ASSIGNMENT_REMINDER       Boolean @default(true)

  // Announcement group configuration
  announcementGroupJid String?

  // Reminder times (HH:MM format)
  dutyReminderTime     String @default("07:00")
  dutyReminderLeadTime String @default("07:00")
  scheduleReminderTime String @default("07:00")
  scheduleReminderLeadTime String @default("20:00")
  assignmentReminderTime String @default("18:00")
  assignmentReminderLeadTime String @default("18:00")
  birthdayReminderTime String @default("09:00")

  // Schedule reminder lead time (days before)
  dutyReminderLeadDays Int @default(0)
  scheduleReminderLeadDays Int @default(0)
  assignmentReminderLeadDays Int @default(0)

  // Fund report configuration
  fundReportDay  Int    @default(1) // Day of month (1-31)
  fundReportTime String @default("08:00")

  // Message templates
  dutyPersonalizedMessage String @default("jangan lupa piket hari ini ya {name}!")
  birthdayMessageTemplate String @default("Selamat ulang tahun {name}! Semoga panjang umur dan sehat selalu!")

  // Timezone configuration (IANA format, e.g., "Asia/Jakarta")
  timezone String @default("system")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
